{
  "name": "Windows 11 on Docker",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspace",

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true
    }
  },

  "forwardPorts": [8006, 3389],
  "portsAttributes": {
    "8006": {
      "label": "Windows 11 Web UI (noVNC)",
      "onAutoForward": "openBrowser",
      "protocol": "http"
    },
    "3389": {
      "label": "Windows 11 RDP",
      "onAutoForward": "notify"
    }
  },

  "postCreateCommand": "bash /workspace/scripts/setup.sh",
  "postStartCommand": "bash /workspace/scripts/start-windows.sh",

  "remoteUser": "root",

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "docker.dockerPath": "/usr/local/bin/docker"
      },
      "extensions": [
        "ms-azuretools.vscode-docker",
        "ms-vscode-remote.remote-containers"
      ]
    }
  
